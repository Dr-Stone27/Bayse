# Bayse API credentials
BAYSE_PUBLIC_KEY=pk_live_your_public_key_here
BAYSE_SECRET_KEY=sk_live_your_secret_key_here

# Strategy: Capital
BTC_MINT_AMOUNT=5000
ETH_MINT_AMOUNT=500

# Strategy: Pricing (NGN fractions — 0.52 = ₦52 per share)
UP_ASK_PRICE=0.52
DOWN_ASK_PRICE=0.54

# Strategy: Timing
WINDOWS_PER_DAY=6
BURN_AT_MINUTE=13
REPRICE_INTERVAL_SEC=30

# Risk Controls
KILL_SWITCH_RATIO=0.70
DAILY_STOP_LOSS=2000
MAX_SINGLE_WINDOW_LOSS=500
BURN_RETRY_INTERVAL_MS=200

# Operation mode — KEEP DRY_RUN=true until 48hrs of clean dry-run completed
DRY_RUN=true
LOG_LEVEL=info
DB_PATH=./bayse_market_making.db
